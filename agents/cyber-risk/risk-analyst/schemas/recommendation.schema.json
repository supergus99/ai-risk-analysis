{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyber-risk.local/schemas/recommendation.schema.json",
  "title": "Risk Recommendation",
  "type": "object",
  "required": [
    "action_id",
    "title",
    "rationale",
    "scenarios_affected",
    "implementation_effort",
    "confidence"
  ],
  "properties": {
    "action_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "scenarios_affected": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "probability_reduction": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "loss_reduction": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "implementation_effort": {
      "type": "string",
      "enum": [
        "Low",
        "Medium",
        "High"
      ]
    },
    "time_to_value": {
      "type": "string",
      "enum": [
        "Short",
        "Medium",
        "Long"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "additionalProperties": false
}
