{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cyber-risk.local/schemas/assessment-output.schema.json",
  "title": "Assessment Output",
  "type": "object",
  "required": [
    "business_profile",
    "threat_actors",
    "scenarios",
    "top_recommendations",
    "explanation"
  ],
  "properties": {
    "business_profile": {
      "$ref": "business-profile.schema.json"
    },
    "threat_actors": {
      "$ref": "threat-actor.schema.json"
    },
    "scenarios": {
      "type": "array",
      "items": {
        "$ref": "scenario.schema.json"
      }
    },
    "top_recommendations": {
      "type": "array",
      "items": {
        "$ref": "recommendation.schema.json"
      }
    },
    "explanation": {
      "$ref": "explanation.schema.json"
    }
  },
  "additionalProperties": false
}
